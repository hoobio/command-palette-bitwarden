<?xml version="1.0" encoding="UTF-8"?>
<!--
  Bitwarden Command Palette Extension MSI installer (WiX 5).

  This MSI is a thin wrapper around the signed MSIX. Microsoft Command Palette
  only discovers extensions via the AppX `windows.appExtension` contract, so
  loose binaries on disk are invisible to it; the MSI therefore needs to do a
  proper MSIX install rather than just dropping files.

  Per-machine install (Scope="perMachine") so the cert can land in
  Cert:\LocalMachine\TrustedPeople, which is the only TrustedPeople store
  Add-AppxPackage actually consults when validating sideloaded MSIX
  signatures from a self-signed publisher. The user-scoped variant looks
  trustworthy on paper but Add-AppxPackage ignores it for sideload trust,
  which is why the README's manual flow also imports to LocalMachine. Cost:
  one UAC prompt at install time. There's no per-user-with-no-UAC path that
  actually works for self-signed sideload; that's a Windows constraint, not
  an MSI choice.

  On install:
    1. Lay down the bundled .msix and .cer under Program Files (so repair
       has something to operate on).
    2. Import-Certificate into Cert:\LocalMachine\TrustedPeople (deferred CA,
       NOT impersonated - runs as SYSTEM with the elevation granted by UAC,
       which is required to write to LocalMachine cert stores).
    3. Add-AppxPackage on the bundled .msix (deferred CA, IMPERSONATED so
       it runs as the installing user and registers the MSIX in that user's
       AppX deployment service - per-user MSIX install, machine-wide cert).

  On uninstall (but not on major upgrade): Remove-AppxPackage by package name.
  We deliberately leave the cert in TrustedPeople; it may be shared with other
  installs and removing it from a deferred CA crosses a user-experience line.

  UI flow uses WixUI_InstallDir (Welcome -> License -> InstallDir -> Verify ->
  Progress -> Finish) so the user gets the standard install ceremony, can
  pick a custom path for the staged .msix/.cer, and can opt to launch
  Microsoft Command Palette from the Finish dialog.

  Preprocessor variables supplied by the build pipeline:
    Version    - four-part version (X.Y.Z.W). Sourced from version.txt.
    Platform   - "x64" or "ARM64". Used to namespace the per-arch UpgradeCode
                 and Component GUIDs. The wix `-arch` flag drives the actual
                 MSI Template summary attribute.
    PayloadDir - directory holding both the per-arch
                 `HoobiBitwardenCommandPaletteExtension.msix` (renamed from
                 the build-msix output) and the publisher cert
                 `HoobiBitwardenCommandPaletteExtension.cer` (copied from the
                 repo root). The CI workflow stages both files into this dir
                 before invoking `wix build`.

  UpgradeCode is stable per-architecture so a newer x64 MSI correctly upgrades
  an installed x64 build. ARM64 ships under a separate UpgradeCode because
  Windows blocks cross-arch upgrades. ProductCode is regenerated per build
  (default `*`).

  PowerToys / PowerToys Preview detection runs in the UI sequence: if neither
  is found, a warning dialog explains that the extension needs the Microsoft
  Command Palette host but lets the user proceed (the AppX install still
  succeeds; the extension just won't be discoverable until PowerToys arrives).
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <?if $(var.Platform) = "ARM64" ?>
    <?define UpgradeCodeGuid = "4B4EA90D-A8EA-4DE8-B668-642922C4077F" ?>
    <?define PlatformLabel = "ARM64" ?>
  <?else?>
    <?define UpgradeCodeGuid = "49FA3F3A-8822-4353-90E2-B2F74483D038" ?>
    <?define PlatformLabel = "x64" ?>
  <?endif?>

  <Package
      Name="Bitwarden Command Palette Extension"
      Manufacturer="Hoobi"
      Version="$(var.Version)"
      UpgradeCode="$(var.UpgradeCodeGuid)"
      Scope="perMachine"
      Compressed="yes"
      InstallerVersion="500">

    <SummaryInformation Description="Bitwarden Command Palette Extension $(var.PlatformLabel) installer" />

    <MajorUpgrade
        DowngradeErrorMessage="A newer version of the Bitwarden Command Palette Extension is already installed."
        Schedule="afterInstallInitialize" />

    <Media Id="1" Cabinet="BitwardenCmdPal.cab" EmbedCab="yes" CompressionLevel="high" />

    <!--
      Resolved relative to this .wxs file (installer\). The .ico is generated
      from Square150x150Logo.scale-200.png and checked in alongside the .wxs.

      WiX 5 dropped the Icon/@Name attribute, so the Id is used verbatim as
      the Icon table key (and as the on-disk filename when extracted to
      %LOCALAPPDATA%\Microsoft\Installer\<ProductCode>\). The .ico extension
      is required for ARP to recognise the stream as an icon resource.
    -->
    <Icon Id="BitwardenCmdPalIcon.ico" SourceFile="$(sys.SOURCEFILEDIR)HoobiBitwardenCommandPaletteExtension.ico" />
    <Property Id="ARPPRODUCTICON" Value="BitwardenCmdPalIcon.ico" />
    <Property Id="ARPHELPLINK" Value="https://github.com/hoobio/command-palette-bitwarden" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/hoobio/command-palette-bitwarden" />
    <Property Id="ARPNOREPAIR" Value="1" />
    <!--
      ARPNOMODIFY is set automatically by the WixUI_InstallDir dialog set, so
      declaring it here would be a duplicate-symbol error.
    -->

    <!--
      PowerToys / PowerToys Preview detection. Each search sets its own
      property to the matched file path; the SetProperty below ORs them into
      a single boolean POWERTOYS_FOUND used by the warning custom action.

      The Microsoft Store version of PowerToys installs as an MSIX package and
      doesn't drop a discoverable PowerToys.exe under Program Files /
      LocalAppData, so this detection is a heuristic - it covers the standard
      installer flows but the warning is intentionally non-blocking either way.
    -->
    <Property Id="POWERTOYS_MACHINE_X64">
      <DirectorySearch Id="PtMachineDirX64" Path="[ProgramFiles64Folder]PowerToys" Depth="0">
        <FileSearch Id="PtMachineExeX64" Name="PowerToys.exe" />
      </DirectorySearch>
    </Property>

    <Property Id="POWERTOYS_MACHINE_X86">
      <DirectorySearch Id="PtMachineDirX86" Path="[ProgramFilesFolder]PowerToys" Depth="0">
        <FileSearch Id="PtMachineExeX86" Name="PowerToys.exe" />
      </DirectorySearch>
    </Property>

    <Property Id="POWERTOYS_USER">
      <DirectorySearch Id="PtUserDir" Path="[LocalAppDataFolder]PowerToys" Depth="0">
        <FileSearch Id="PtUserExe" Name="PowerToys.exe" />
      </DirectorySearch>
    </Property>

    <Property Id="POWERTOYS_PREVIEW">
      <DirectorySearch Id="PtPreviewDir" Path="[ProgramFiles64Folder]PowerToys (Preview)" Depth="0">
        <FileSearch Id="PtPreviewExe" Name="PowerToys.exe" />
      </DirectorySearch>
    </Property>

    <CustomAction Id="WarnNoPowerToys"
                  Script="jscript"
                  ScriptSourceFile="$(sys.SOURCEFILEDIR)WarnNoPowerToys.js"
                  Execute="immediate"
                  Return="check" />

    <SetProperty Id="POWERTOYS_FOUND"
                 Value="1"
                 Sequence="ui"
                 Before="WarnNoPowerToys"
                 Condition="POWERTOYS_MACHINE_X64 OR POWERTOYS_MACHINE_X86 OR POWERTOYS_USER OR POWERTOYS_PREVIEW" />

    <InstallUISequence>
      <Custom Action="WarnNoPowerToys" After="AppSearch" Condition="NOT POWERTOYS_FOUND AND NOT Installed" />
    </InstallUISequence>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="HoobiBitwardenCommandPaletteExtension" />
    </StandardDirectory>

    <Feature Id="Main" Title="Bitwarden Command Palette" Level="1" AllowAdvertise="no" Display="expand" ConfigurableDirectory="INSTALLFOLDER">
      <ComponentGroupRef Id="WrappedPayload" />
    </Feature>

    <!--
      Cert + AppX wiring. Each operation is split into two CAs:
        - "<Name>_Cmd" (immediate): builds the powershell.exe command line into
          a property whose name matches the deferred CA. [#FileId] tokens
          resolve at this point because CostFinalize has run.
        - "<Name>"     (deferred):  WixQuietExec reads the property of the same
          name and invokes powershell.

      The cert and AppX actions run in *different* contexts:
        - ImportCert is NOT impersonated, so it runs as SYSTEM with the
          elevation UAC granted us. Required because Cert:\LocalMachine\*
          stores can only be modified by an admin / SYSTEM, and the
          LocalMachine TrustedPeople store is the only one Add-AppxPackage
          consults when validating sideloaded MSIX from a self-signed
          publisher (the user-scoped variant looks ignored for sideload
          trust in practice).
        - AddAppxPackage IS impersonated so PowerShell runs as the
          installing user. Add-AppxPackage without -AllUsers is a per-user
          operation and needs to land in that user's deployment store, not
          SYSTEM's.
        - RemoveAppxPackage matches AddAppxPackage's impersonation so it
          tears down the same user's installation.

      Deferred CAs run after InstallFiles so [#PublisherCer] and [#MsixPackage]
      both point at on-disk paths. ImportCert outputs to Out-Null but
      Add-AppxPackage's verbose progress lands in the MSI log when /l*v is
      supplied to msiexec. Failures bubble up via Return="check" and the MSI
      rolls back.
    -->
    <CustomAction Id="ImportCert_Cmd"
                  Property="ImportCert"
                  Value="&quot;powershell.exe&quot; -NoProfile -NonInteractive -ExecutionPolicy Bypass -Command &quot;Import-Certificate -FilePath '[#PublisherCer]' -CertStoreLocation Cert:\LocalMachine\TrustedPeople | Out-Null&quot;" />
    <CustomAction Id="ImportCert"
                  BinaryRef="Wix4UtilCA_X86"
                  DllEntry="WixQuietExec"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <CustomAction Id="AddAppxPackage_Cmd"
                  Property="AddAppxPackage"
                  Value="&quot;powershell.exe&quot; -NoProfile -NonInteractive -ExecutionPolicy Bypass -Command &quot;Add-AppxPackage -Path '[#MsixPackage]' -ForceUpdateFromAnyVersion&quot;" />
    <CustomAction Id="AddAppxPackage"
                  BinaryRef="Wix4UtilCA_X86"
                  DllEntry="WixQuietExec"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="check" />

    <!--
      Uninstall: match by package name (the Identity Name in Package.appxmanifest)
      so we don't have to plumb the exact PackageFullName through CustomActionData.
      Return="ignore" so a missing package (e.g. user already uninstalled the
      AppX manually) doesn't block MSI removal.
    -->
    <CustomAction Id="RemoveAppxPackage_Cmd"
                  Property="RemoveAppxPackage"
                  Value="&quot;powershell.exe&quot; -NoProfile -NonInteractive -ExecutionPolicy Bypass -Command &quot;Get-AppxPackage -Name 'Hoobi.BitwardenCommandPaletteExtension' | Remove-AppxPackage&quot;" />
    <CustomAction Id="RemoveAppxPackage"
                  BinaryRef="Wix4UtilCA_X86"
                  DllEntry="WixQuietExec"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore" />

    <InstallExecuteSequence>
      <!-- Install / repair / upgrade-new-product: stage files, import cert,
           register AppX. The `NOT REMOVE` guard skips these on uninstall AND
           on the old product's RemoveExistingProducts pass during a major
           upgrade. -->
      <Custom Action="ImportCert_Cmd"      After="InstallFiles"   Condition="NOT REMOVE" />
      <Custom Action="ImportCert"          After="ImportCert_Cmd" Condition="NOT REMOVE" />
      <Custom Action="AddAppxPackage_Cmd"  After="ImportCert"     Condition="NOT REMOVE" />
      <Custom Action="AddAppxPackage"      After="AddAppxPackage_Cmd" Condition="NOT REMOVE" />

      <!-- Uninstall: tear down the AppX before MSI's RemoveFiles wipes the
           staged .msix. Skipped during major upgrade (UPGRADINGPRODUCTCODE
           is set on the old product's uninstall pass) so we don't briefly
           leave the user without the extension between RemoveAppxPackage and
           the new product's AddAppxPackage. -->
      <Custom Action="RemoveAppxPackage_Cmd" Before="RemoveAppxPackage" Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE" />
      <Custom Action="RemoveAppxPackage"     Before="RemoveFiles"        Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE" />
    </InstallExecuteSequence>

    <!--
      WixUI_InstallDir provides the configurable install path dialog. The
      Finish dialog gets a "Launch Microsoft Command Palette" optional
      checkbox bound to a WixShellExec custom action so the user can jump
      straight into Command Palette after install.

      The launch target is the Microsoft Command Palette MSIX AUMID via the
      `shell:AppsFolder\` namespace, which ShellExecute resolves to the
      installed packaged app. If Command Palette isn't installed, ShellExecute
      fails silently - the install itself has already succeeded.
    -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch Microsoft Command Palette" />
    <Property Id="WixShellExecTarget" Value="shell:AppsFolder\Microsoft.CommandPalette_8wekyb3d8bbwe!App" />

    <CustomAction Id="LaunchApplication"
                  BinaryRef="Wix4UtilCA_X86"
                  DllEntry="WixShellExec"
                  Impersonate="yes" />

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="$(sys.SOURCEFILEDIR)License.rtf" />
    <!--
      Brand the WiX UI chrome: WixUIBannerBmp (493x58) is the horizontal
      banner on inner dialogs; WixUIDialogBmp (493x312) is the Welcome / Exit
      backdrop with the visible left ~164 px showing a #1d1d1d panel + logo.
    -->
    <WixVariable Id="WixUIBannerBmp" Value="$(sys.SOURCEFILEDIR)WixUIBannerBmp.bmp" />
    <WixVariable Id="WixUIDialogBmp" Value="$(sys.SOURCEFILEDIR)WixUIDialogBmp.bmp" />

    <UI>
      <Publish Dialog="ExitDialog"
               Control="Finish"
               Event="DoAction"
               Value="LaunchApplication"
               Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed" />
    </UI>

  </Package>

  <!--
    Wrapped payload: just the signed MSIX + the publisher cert that needs to
    sit in TrustedPeople for the AppX deployment service to trust it. The
    explicit File Ids let custom actions reference these via [#PublisherCer]
    / [#MsixPackage] tokens without depending on full paths.
  -->
  <Fragment>
    <ComponentGroup Id="WrappedPayload" Directory="INSTALLFOLDER">
      <Component Id="MsixPackageComponent" Guid="1D27B6DE-D44E-4581-8C24-686BAD9B7968">
        <File Id="MsixPackage"
              Source="$(var.PayloadDir)\HoobiBitwardenCommandPaletteExtension.msix"
              KeyPath="yes" />
      </Component>
      <Component Id="PublisherCerComponent" Guid="3BB4037A-6706-4BEA-BEB0-59096B31AC6B">
        <File Id="PublisherCer"
              Source="$(var.PayloadDir)\HoobiBitwardenCommandPaletteExtension.cer"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

</Wix>
