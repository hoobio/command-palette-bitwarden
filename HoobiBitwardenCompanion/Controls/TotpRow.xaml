<UserControl
    x:Class="HoobiBitwardenCompanion.Controls.TotpRow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="OnLoaded"
    Unloaded="OnUnloaded">

    <StackPanel Spacing="2">
        <TextBlock Text="Verification code (TOTP)" Style="{StaticResource MutedCaptionTextStyle}" />
        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="CodeText"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       FontFamily="Consolas"
                       FontSize="20"
                       CharacterSpacing="50"
                       IsTextSelectionEnabled="True" />

            <!-- Countdown ring: a determinate ProgressRing depleting over the period, with the
                 remaining seconds shown in the centre. Coloured green, then amber/red as it runs out. -->
            <Grid Grid.Column="1" Width="32" Height="32" VerticalAlignment="Center">
                <ProgressRing x:Name="CountdownRing"
                              IsIndeterminate="False"
                              Minimum="0"
                              Width="32" Height="32" />
                <TextBlock x:Name="SecondsText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="11" />
            </Grid>

            <Button x:Name="CopyButton"
                    Grid.Column="2"
                    Style="{StaticResource GhostIconButtonStyle}"
                    ToolTipService.ToolTip="Copy code"
                    VerticalAlignment="Center"
                    Click="OnCopyClick">
                <FontIcon Glyph="&#xE8C8;" FontSize="16" />
            </Button>
        </Grid>
    </StackPanel>
</UserControl>
