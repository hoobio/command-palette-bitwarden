<UserControl
    x:Class="HoobiBitwardenCompanion.Controls.GeneratorControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <StackPanel Spacing="{StaticResource SpacingMedium}">

        <!-- Generated value -->
        <Border Style="{StaticResource SubtleCardStyle}">
            <Grid ColumnSpacing="{StaticResource SpacingSmall}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ValueText"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           FontFamily="Consolas"
                           FontSize="16"
                           IsTextSelectionEnabled="True"
                           TextWrapping="Wrap" />
                <Button x:Name="RegenerateButton"
                        Grid.Column="1"
                        Style="{StaticResource GhostIconButtonStyle}"
                        ToolTipService.ToolTip="Regenerate"
                        Click="OnRegenerateClick">
                    <FontIcon Glyph="&#xE72C;" FontSize="16" />
                </Button>
                <Button x:Name="CopyButton"
                        Grid.Column="2"
                        Style="{StaticResource GhostIconButtonStyle}"
                        ToolTipService.ToolTip="Copy"
                        Click="OnCopyClick">
                    <FontIcon Glyph="&#xE8C8;" FontSize="16" />
                </Button>
            </Grid>
        </Border>

        <!-- Mode selector -->
        <controls:RadioButtons x:Name="ModeSelector" MaxColumns="2" SelectedIndex="0" SelectionChanged="OnModeChanged">
            <x:String>Password</x:String>
            <x:String>Passphrase</x:String>
        </controls:RadioButtons>

        <!-- Password options -->
        <StackPanel x:Name="PasswordOptions" Spacing="{StaticResource SpacingSmall}">
            <Grid ColumnSpacing="{StaticResource SpacingMedium}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Length" VerticalAlignment="Center" />
                <Slider x:Name="LengthSlider" Grid.Column="1" Minimum="5" Maximum="128" Value="20"
                        VerticalAlignment="Center" ValueChanged="OnOptionChanged" />
                <TextBlock x:Name="LengthValueText" Grid.Column="2" Text="20" VerticalAlignment="Center"
                           MinWidth="28" TextAlignment="Right" />
            </Grid>

            <Grid ColumnSpacing="{StaticResource SpacingMedium}" RowSpacing="{StaticResource SpacingXSmall}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <CheckBox x:Name="UppercaseToggle" Grid.Row="0" Grid.Column="0" Content="A-Z" IsChecked="True" Click="OnOptionClicked" />
                <CheckBox x:Name="LowercaseToggle" Grid.Row="0" Grid.Column="1" Content="a-z" IsChecked="True" Click="OnOptionClicked" />
                <CheckBox x:Name="NumbersToggle" Grid.Row="1" Grid.Column="0" Content="0-9" IsChecked="True" Click="OnOptionClicked" />
                <CheckBox x:Name="SymbolsToggle" Grid.Row="1" Grid.Column="1" Content="!@#$%^&amp;*" IsChecked="True" Click="OnOptionClicked" />
            </Grid>

            <Grid ColumnSpacing="{StaticResource SpacingMedium}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="{StaticResource SpacingXSmall}">
                    <TextBlock Text="Min numbers" Style="{StaticResource MutedCaptionTextStyle}" />
                    <controls:NumberBox x:Name="MinNumberBox" Value="1" Minimum="0" Maximum="9"
                                        SpinButtonPlacementMode="Inline" ValueChanged="OnOptionChanged" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="{StaticResource SpacingXSmall}">
                    <TextBlock Text="Min special" Style="{StaticResource MutedCaptionTextStyle}" />
                    <controls:NumberBox x:Name="MinSpecialBox" Value="1" Minimum="0" Maximum="9"
                                        SpinButtonPlacementMode="Inline" ValueChanged="OnOptionChanged" />
                </StackPanel>
            </Grid>

            <CheckBox x:Name="AvoidAmbiguousToggle" Content="Avoid ambiguous characters" IsChecked="True" Click="OnOptionClicked" />
        </StackPanel>

        <!-- Passphrase options -->
        <StackPanel x:Name="PassphraseOptions" Spacing="{StaticResource SpacingSmall}" Visibility="Collapsed">
            <Grid ColumnSpacing="{StaticResource SpacingMedium}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="{StaticResource SpacingXSmall}">
                    <TextBlock Text="Number of words" Style="{StaticResource MutedCaptionTextStyle}" />
                    <controls:NumberBox x:Name="WordsBox" Value="6" Minimum="3" Maximum="20"
                                        SpinButtonPlacementMode="Inline" ValueChanged="OnOptionChanged" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="{StaticResource SpacingXSmall}">
                    <TextBlock Text="Separator" Style="{StaticResource MutedCaptionTextStyle}" />
                    <TextBox x:Name="SeparatorBox" Text="-" MaxLength="3" TextChanged="OnSeparatorChanged" />
                </StackPanel>
            </Grid>
            <CheckBox x:Name="CapitalizeToggle" Content="Capitalize" Click="OnOptionClicked" />
            <CheckBox x:Name="IncludeNumberToggle" Content="Include number" IsChecked="True" Click="OnOptionClicked" />
        </StackPanel>

    </StackPanel>
</UserControl>
