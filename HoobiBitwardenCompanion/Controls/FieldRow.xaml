<UserControl
    x:Class="HoobiBitwardenCompanion.Controls.FieldRow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <StackPanel Spacing="2">
        <TextBlock Text="{x:Bind Label, Mode=OneWay}" Style="{StaticResource MutedCaptionTextStyle}" />
        <Grid ColumnSpacing="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Read-only display -->
            <!-- Text selection is off so Ctrl+C (copy username) reaches the page accelerator instead of
                 being consumed as a text-copy of an empty selection. Copy via the button or shortcut. -->
            <TextBlock x:Name="DisplayText"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap" />

            <!-- Clickable link (shown for link fields whose value is a real http(s) URI). -->
            <HyperlinkButton x:Name="LinkText"
                             Grid.Column="0"
                             Visibility="Collapsed"
                             Padding="0"
                             HorizontalAlignment="Left" />

            <!-- Editable -->
            <TextBox x:Name="EditBox"
                     Grid.Column="0"
                     Visibility="Collapsed"
                     TextChanged="OnEditTextChanged" />

            <Button x:Name="RevealButton"
                    Grid.Column="1"
                    Style="{StaticResource GhostIconButtonStyle}"
                    Visibility="Collapsed"
                    ToolTipService.ToolTip="Show / hide"
                    Click="OnRevealClick">
                <FontIcon x:Name="RevealIcon" Glyph="&#xE7B3;" FontSize="16" />
            </Button>

            <Button x:Name="RegenerateButton"
                    Grid.Column="2"
                    Style="{StaticResource GhostIconButtonStyle}"
                    Visibility="Collapsed"
                    ToolTipService.ToolTip="Regenerate"
                    Click="OnRegenerateClick">
                <FontIcon Glyph="&#xE72C;" FontSize="16" />
            </Button>

            <Button x:Name="CopyButton"
                    Grid.Column="3"
                    Style="{StaticResource GhostIconButtonStyle}"
                    ToolTipService.ToolTip="Copy"
                    Click="OnCopyClick">
                <FontIcon Glyph="&#xE8C8;" FontSize="16" />
            </Button>
        </Grid>
    </StackPanel>
</UserControl>
