<UserControl
    x:Class="HoobiBitwardenCompanion.Controls.UriListEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <StackPanel Spacing="{StaticResource SpacingSmall}">
        <StackPanel x:Name="RowsPanel" Spacing="{StaticResource SpacingSmall}" />
        <Button x:Name="AddButton" Click="OnAddClick" HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE710;" FontSize="14" />
                <TextBlock Text="Add website" />
            </StackPanel>
        </Button>
    </StackPanel>
</UserControl>
