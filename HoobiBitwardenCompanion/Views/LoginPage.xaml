<Page
    x:Class="HoobiBitwardenCompanion.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <StackPanel Spacing="{StaticResource SpacingMedium}" VerticalAlignment="Top" MaxWidth="420" HorizontalAlignment="Center" Padding="{StaticResource PagePadding}">
        <StackPanel Spacing="{StaticResource SpacingXSmall}">
            <TextBlock Text="Bitwarden" Style="{StaticResource PageHeaderTextStyle}" />
            <TextBlock x:Name="SubheaderText" Style="{StaticResource PageSubheaderTextStyle}" />
        </StackPanel>

        <ProgressRing x:Name="Busy" IsActive="False" HorizontalAlignment="Left" Width="24" Height="24" />

        <Border Style="{StaticResource SectionCardStyle}">
            <StackPanel Spacing="{StaticResource SpacingMedium}">

                <!-- Login (unauthenticated) -->
                <StackPanel x:Name="LoginPanel" Spacing="{StaticResource SpacingSmall}" Visibility="Collapsed">
                    <TextBox x:Name="EmailBox" Header="Email" InputScope="EmailSmtpAddress" />
                    <PasswordBox x:Name="LoginPasswordBox" Header="Master password" />
                    <Button x:Name="LoginButton" Content="Log in" Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch" Click="OnLoginClick" />
                </StackPanel>

                <!-- Unlock (authenticated but locked) -->
                <StackPanel x:Name="UnlockPanel" Spacing="{StaticResource SpacingSmall}" Visibility="Collapsed">
                    <PasswordBox x:Name="UnlockPasswordBox" Header="Master password" />
                    <Button x:Name="UnlockButton" Content="Unlock" Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch" Click="OnUnlockClick" />
                    <Button x:Name="BiometricButton" HorizontalAlignment="Stretch" Click="OnBiometricClick">
                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                            <FontIcon Glyph="&#xE8D7;" FontSize="16" />
                            <TextBlock Text="Unlock with Windows Hello" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- 2FA / device verification code -->
                <StackPanel x:Name="CodePanel" Spacing="{StaticResource SpacingSmall}" Visibility="Collapsed">
                    <TextBlock x:Name="CodeCaption" Style="{StaticResource MutedCaptionTextStyle}" />
                    <TextBox x:Name="CodeBox" Header="Code" InputScope="Number" />
                    <Button x:Name="CodeButton" Content="Submit" Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch" Click="OnCodeClick" />
                </StackPanel>

            </StackPanel>
        </Border>

        <TextBlock x:Name="StatusText" Style="{StaticResource MutedCaptionTextStyle}" TextWrapping="Wrap" Visibility="Collapsed" />
    </StackPanel>
</Page>
