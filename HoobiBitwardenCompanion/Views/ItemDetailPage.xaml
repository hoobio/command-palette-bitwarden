<Page
    x:Class="HoobiBitwardenCompanion.Views.ItemDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Fields. The ScrollViewer spans edge to edge so its scrollbar sits on the window edge;
             the inner content carries the horizontal padding instead. -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="FieldsPanel" Spacing="{StaticResource SpacingMedium}"
                        Padding="16,4,16,8" />
        </ScrollViewer>

        <!-- Loading state: shown while the item is fetched (instant when served from the extension's
             vault cache; a moment longer on a cache miss that falls back to the CLI). -->
        <StackPanel x:Name="LoadingPanel" Grid.Row="0"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}"
                    Visibility="Collapsed">
            <ProgressRing IsActive="True" Width="20" Height="20" />
            <TextBlock x:Name="LoadingText" VerticalAlignment="Center"
                       Style="{StaticResource MutedCaptionTextStyle}" />
        </StackPanel>

        <!-- Footer: a compact action row. -->
        <StackPanel Grid.Row="1" Spacing="4" Padding="12,4,12,8">
            <TextBlock x:Name="StatusText" Style="{StaticResource MutedCaptionTextStyle}" Visibility="Collapsed" />
            <Grid ColumnSpacing="{StaticResource SpacingSmall}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <HyperlinkButton x:Name="WebVaultButton" Grid.Column="0" Content="Open in Web Vault"
                                 HorizontalAlignment="Left" Padding="4,2" Click="OnWebVaultClick" />
                <Button x:Name="EditButton" Grid.Column="1" Content="Edit" Padding="14,4" MinHeight="0" Click="OnEditClick" />
                <Button x:Name="CancelButton" Grid.Column="2" Content="Cancel" Padding="14,4" MinHeight="0" Visibility="Collapsed" Click="OnCancelClick" />
                <Button x:Name="SaveButton" Grid.Column="3" Content="Save" Style="{StaticResource AccentButtonStyle}"
                        Padding="14,4" MinHeight="0" Visibility="Collapsed" Click="OnSaveClick" />
            </Grid>
        </StackPanel>
    </Grid>
</Page>
