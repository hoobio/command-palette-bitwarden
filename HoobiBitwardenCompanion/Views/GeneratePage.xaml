<Page
    x:Class="HoobiBitwardenCompanion.Views.GeneratePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:HoobiBitwardenCompanion.Controls"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <StackPanel Spacing="{StaticResource SpacingMedium}" VerticalAlignment="Top" Padding="{StaticResource PagePadding}">
        <StackPanel Spacing="{StaticResource SpacingXSmall}">
            <TextBlock Text="Generate" Style="{StaticResource PageHeaderTextStyle}" />
            <TextBlock Text="Create a password or passphrase. Nothing is saved to your vault."
                       Style="{StaticResource PageSubheaderTextStyle}" />
        </StackPanel>

        <Border Style="{StaticResource SectionCardStyle}">
            <controls:GeneratorControl x:Name="Generator" />
        </Border>

        <TextBlock x:Name="ErrorText"
                   Style="{StaticResource MutedCaptionTextStyle}"
                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                   Visibility="Collapsed" />
    </StackPanel>
</Page>
