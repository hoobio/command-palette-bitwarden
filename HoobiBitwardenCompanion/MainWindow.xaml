<Window
    x:Class="HoobiBitwardenCompanion.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Bitwarden">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- No title text: the page content carries its own header; the title bar is just the drag
             region + caption buttons. -->
        <controls:TitleBar
            x:Name="AppTitleBar"
            Grid.Row="0" />

        <Grid Grid.Row="1" Padding="{StaticResource PagePadding}">
            <Frame x:Name="ContentFrame"
                   MaxWidth="{StaticResource ContentMaxWidth}"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch" />
        </Grid>
    </Grid>
</Window>
