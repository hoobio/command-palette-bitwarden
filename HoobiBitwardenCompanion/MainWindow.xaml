<Window
    x:Class="HoobiBitwardenCompanion.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Bitwarden">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- No title text: the page content carries its own header; the title bar is just the drag
             region + caption buttons. -->
        <controls:TitleBar
            x:Name="AppTitleBar"
            Grid.Row="0" />

        <Grid Grid.Row="1">
            <Frame x:Name="ContentFrame"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch" />

            <!-- In-app "copied" toast: a transient pill above the bottom edge, shown when a value is
                 copied to the clipboard. -->
            <Border x:Name="CopyToast"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,24"
                    Padding="16,8"
                    CornerRadius="16"
                    Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                    Opacity="0"
                    IsHitTestVisible="False">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE73E;" FontSize="14"
                              Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                    <TextBlock Text="Copied to clipboard" VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
